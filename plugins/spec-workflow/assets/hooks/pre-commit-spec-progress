#!/usr/bin/env sh
# Spec workflow progress guard.
#
# Install by copying this file to .git/hooks/pre-commit and making it executable.
# It blocks commits that stage business-code changes while an active spec
# workflow exists under docs/specs/ but that workflow's tasks.md, progress.md,
# spec.yml, or acceptance progress file was not updated in the same commit.

set -eu

if [ ! -d "docs/specs" ]; then
  exit 0
fi

SCRIPT="plugins/spec-workflow/scripts/spec_progress.py"
if [ ! -f "$SCRIPT" ]; then
  echo "Spec workflow hook skipped: $SCRIPT not found." >&2
  exit 0
fi

if command -v python >/dev/null 2>&1; then
  PYTHON_BIN=python
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN=python3
else
  echo "Spec workflow hook failed: neither python nor python3 was found." >&2
  exit 1
fi

"$PYTHON_BIN" "$SCRIPT" guard-all docs/specs/
